{
  "name": "playstats-backend",
  "version": "1.0.0",
  "description": "PlayStats Backend API - Sports Statistics Platform",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "sports",
    "statistics",
    "tournament",
    "cricket",
    "football",
    "volleyball"
  ],
  "author": "PlayStats Team",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.49.2",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.7.11",
    "postgres": "^3.4.6",
    "zod": "^3.24.1",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  }
}
